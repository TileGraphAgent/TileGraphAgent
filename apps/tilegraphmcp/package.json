{
  "name": "tilegraphmcp",
  "version": "0.1.0",
  "description": "MCP Server — exposes 3D Tiles + Knowledge Graph to LLM agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@cloudflare/workers-types": "^4.20260529.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "hono": "^4.12.23",
    "neo4j-driver": "^6.0.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "vitest": {
    "include": ["src/tests/**/*.test.ts", "tests/**/*.test.ts"],
    "environment": "node",
    "testTimeout": 60000
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
